# Copy to .env (or set these in your host's dashboard). Do NOT commit real values.
ADMIN_KEY=pick-a-long-random-password
PUBLIC_URL=https://your-app-url.example.com

# Optional — enables the "Text Link" button (sends the tracking link by SMS)
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your_auth_token
# TWILIO_FROM=+15550100000
